{
	"name": "kstack-docs",
	"routes": [
		{
			"pattern": "kstack.sh",
			"custom_domain": true
		}
	],
	"compatibility_date":"2026-04-14",
	"compatibility_flags": ["global_fetch_strictly_public", "nodejs_compat"],
	"preview_urls": true,
	"observability": {
		"enabled": true
	},
	"assets": {
		"directory": "./dist",
		"html_handling": "drop-trailing-slash",
		"not_found_handling": "404-page"
	}
}
